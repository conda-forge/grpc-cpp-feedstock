From 2bb00ab69e1d54fc91e1580a455f97609ba56b0c Mon Sep 17 00:00:00 2001
From: "H. Vetinari" <h.vetinari@gmx.com>
Date: Tue, 31 Dec 2024 13:40:58 +0100
Subject: [PATCH 16/16] set GRPCAPI when building & consuming grpc

see https://github.com/grpc/grpc/blob/v1.68.2/include/grpc/support/port_platform.h#L725-L731
---
 CMakeLists.txt | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 0f0deee761..34358d61dc 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -2153,7 +2153,11 @@ if(WIN32 AND MSVC)
     COMPILE_PDB_OUTPUT_DIRECTORY "${CMAKE_BINARY_DIR}"
   )
   if(BUILD_SHARED_LIBS)
+    # build gpr
     set_target_properties(gpr PROPERTIES DEFINE_SYMBOL "GPR_DLL_EXPORTS")
+    target_compile_definitions(gpr PRIVATE "GPRAPI=__declspec(dllexport)")
+    # consume gpr
+    target_compile_definitions(gpr INTERFACE "GPRAPI=__declspec(dllimport)")
     target_compile_definitions(gpr INTERFACE "GPR_DLL_IMPORTS")
   endif()
   if(gRPC_INSTALL)
@@ -3097,7 +3101,11 @@ if(WIN32 AND MSVC)
     COMPILE_PDB_OUTPUT_DIRECTORY "${CMAKE_BINARY_DIR}"
   )
   if(BUILD_SHARED_LIBS)
+    # build grpc
     set_target_properties(grpc PROPERTIES DEFINE_SYMBOL "GRPC_DLL_EXPORTS")
+    target_compile_definitions(grpc PRIVATE "GRPCAPI=__declspec(dllexport)")
+    # consume grpc
+    target_compile_definitions(grpc INTERFACE "GRPCAPI=__declspec(dllimport)")
     target_compile_definitions(grpc INTERFACE "GRPC_DLL_IMPORTS")
   endif()
   if(gRPC_INSTALL)
@@ -4687,6 +4695,7 @@ if(WIN32 AND MSVC)
   if(BUILD_SHARED_LIBS)
     set_target_properties(grpc++ PROPERTIES DEFINE_SYMBOL "GRPCXX_DLL_EXPORTS")
     target_compile_definitions(grpc++ INTERFACE "GRPCXX_DLL_IMPORTS")
+    target_compile_definitions(grpc PRIVATE "GRPCAPI=__declspec(dllimport)")
   endif()
   if(gRPC_INSTALL)
     install(FILES ${CMAKE_CURRENT_BINARY_DIR}/grpc++.pdb
@@ -4967,6 +4976,7 @@ if(WIN32 AND MSVC)
       "GPR_DLL_IMPORTS"
       "GRPC_DLL_IMPORTS"
       "GRPCXX_DLL_IMPORTS"
+      "GRPCAPI=__declspec(dllimport)"
     )
   endif()
   if(gRPC_INSTALL)
@@ -5038,6 +5048,7 @@ if(WIN32 AND MSVC)
       "GPR_DLL_IMPORTS"
       "GRPC_DLL_IMPORTS"
       "GRPCXX_DLL_IMPORTS"
+      "GRPCAPI=__declspec(dllimport)"
     )
   endif()
   if(gRPC_INSTALL)
@@ -5119,6 +5130,7 @@ if(WIN32 AND MSVC)
       "GPR_DLL_IMPORTS"
       "GRPC_DLL_IMPORTS"
       "GRPCXX_DLL_IMPORTS"
+      "GRPCAPI=__declspec(dllimport)"
     )
   endif()
   if(gRPC_INSTALL)
@@ -5429,6 +5441,7 @@ if(WIN32 AND MSVC)
   if(BUILD_SHARED_LIBS)
     set_target_properties(grpc++_unsecure PROPERTIES DEFINE_SYMBOL "GRPCXX_DLL_EXPORTS")
     target_compile_definitions(grpc++_unsecure INTERFACE "GRPCXX_DLL_IMPORTS")
+    target_compile_definitions(grpc++_unsecure PRIVATE "GRPCAPI=__declspec(dllimport)")
   endif()
   if(gRPC_INSTALL)
     install(FILES ${CMAKE_CURRENT_BINARY_DIR}/grpc++_unsecure.pdb
