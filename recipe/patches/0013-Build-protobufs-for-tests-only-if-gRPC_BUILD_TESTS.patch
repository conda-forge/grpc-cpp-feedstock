From e7641ccb20a4680d06514b6f3753c449caf25079 Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwe.korn@quantco.com>
Date: Thu, 28 Nov 2024 20:40:54 +0100
Subject: [PATCH 13/15] Build protobufs for tests only if gRPC_BUILD_TESTS

---
 CMakeLists.txt | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 6fb7d1f808..52b3ee9c62 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -707,6 +707,9 @@ protobuf_generate_grpc_cpp_with_import_path_correction(
 protobuf_generate_grpc_cpp_with_import_path_correction(
   src/proto/grpc/status/status.proto src/proto/grpc/status/status.proto
 )
+
+if(gRPC_BUILD_TESTS)
+
 protobuf_generate_grpc_cpp_with_import_path_correction(
   src/proto/grpc/testing/benchmark_service.proto src/proto/grpc/testing/benchmark_service.proto
 )
@@ -1301,7 +1304,6 @@ protobuf_generate_grpc_cpp_with_import_path_correction(
 )
 endif()
 
-if(gRPC_BUILD_TESTS)
   add_custom_target(buildtests_c)
   if(_gRPC_PLATFORM_LINUX OR _gRPC_PLATFORM_MAC OR _gRPC_PLATFORM_POSIX)
     add_dependencies(buildtests_c fd_conservation_posix_test)
